# =============================================================================
# Research Peptides ES — environment variables
#
# Stack
#   • Frontend: Vite + React (this repo)
#   • Database: Supabase (products, orders, auth)
#   • Email:    Resend (order + contact notifications via /api/email/*)
#   • Hosting:  Vercel (static app + serverless api/*)
#
# Setup
#   1. Copy this file to `.env` and fill in values (never commit `.env`).
#   2. Local UI only:        npm run dev
#   3. Local UI + API/email: vercel dev   (loads .env for api routes + Resend)
#   4. Production:           Vercel → Project → Settings → Environment Variables
#
# Vercel variable rules
#   • VITE_*     → embedded in the browser build (public). Anon key + tawk.to IDs only.
#   • No VITE_   → server-only (api/*, scripts). Service role + Resend API key here.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — frontend (required for npm run dev / Vite build)
# Dashboard → Project Settings → API → Project URL + anon public key
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"


# -----------------------------------------------------------------------------
# Supabase — server & scripts (required for /api/* and npm run db:seed:supabase)
# Same Project URL as above + service_role key (secret — never VITE_)
# Used by: api/product-feed, api/email/*, api/lib/supabaseOrders, seed scripts
# -----------------------------------------------------------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Optional — legacy UK/previous Supabase (for npm run db:copy:catalog:apply)
# Dashboard → old project → Settings → API → service_role (never commit real keys)
# SOURCE_SUPABASE_URL="https://old-project.supabase.co"
# SOURCE_SUPABASE_SERVICE_ROLE_KEY="old-service-role-key"


# -----------------------------------------------------------------------------
# Site URL (Vercel production domain — used in product feed, email links)
# Set to your Vercel URL or custom domain, e.g. https://researchpeptides.es
# -----------------------------------------------------------------------------
SITE_URL="https://researchpeptides.es"
VITE_SITE_URL="https://researchpeptides.es"
VITE_SUPPORT_EMAIL="info@researchpeptides.es"


# -----------------------------------------------------------------------------
# Resend — transactional email (required for order + contact emails on Vercel)
# https://resend.com → API Keys + verify sending domain for RESEND_FROM
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM="Research Peptides ES <noreply@researchpeptides.es>"
EMAIL_ADMIN_TO="info@researchpeptides.es"
EMAIL_BRAND_NAME="Research Peptides ES"
EMAIL_SUPPORT_ADDRESS="info@researchpeptides.es"
WHATSAPP_NUMBER="34619862542"

# Optional
# EMAIL_FROM="same as RESEND_FROM if you prefer an alias"
# EMAIL_DRY_RUN="true"
# RESEND_BASE_URL="https://api.resend.com"


# -----------------------------------------------------------------------------
# Admin access hint (frontend only — DB role must still be admin in Supabase)
# See server/migrations/003_admin_rls_orders_products.sql
# -----------------------------------------------------------------------------
# VITE_ADMIN_EMAILS="you@example.com"


# -----------------------------------------------------------------------------
# Chatway live chat (optional — browser)
# Dashboard → Widget Settings → embed code (widget id from script URL)
# Recommended dashboard colors: widget #A91D3A, accent gold #C9A961, position Left
# -----------------------------------------------------------------------------
# VITE_CHATWAY_WIDGET_ID="CU5NPjpRNtyT"
# Lift chat panel above mobile bottom nav (px)
# VITE_CHATWAY_MOBILE_OFFSET_Y="96"


# -----------------------------------------------------------------------------
# Crypto checkout — Plisio / Psilio (optional, server-only)
# Callback URLs must point at your Vercel deployment /api/payments/psilio/*
# -----------------------------------------------------------------------------
# PSILIO_SECRET_KEY="your_plisio_secret"
# PSILIO_CREATE_INVOICE_URL="https://api.plisio.net/api/v1/invoices/new"
# PSILIO_STATUS_URL="https://your-app.vercel.app/api/payments/psilio/status"
# PSILIO_SUCCESS_URL="https://your-app.vercel.app/checkout?payment=success"
# PSILIO_FAILED_URL="https://your-app.vercel.app/checkout?payment=failed"


# -----------------------------------------------------------------------------
# Local dev only (optional)
# -----------------------------------------------------------------------------
# VITE_DEV_API_PROXY="http://127.0.0.1:3000"
# VITE_SITE_URL="http://localhost:5173"
