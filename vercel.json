{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/es",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/es/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/email/*.ts": {
      "maxDuration": 30
    },
    "api/product-feed.ts": {
      "maxDuration": 30
    },
    "api/payments/psilio/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/product-feed.xml",
      "destination": "/api/product-feed"
    },
    {
      "source": "/((?!api/|assets/|favicon|src/).*)",
      "destination": "/index.html"
    }
  ]
}
